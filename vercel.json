{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "framework": null,
  "redirects": [
    { "source": "/pasto-en-rollo-san-agustin-tampico", "destination": "/", "permanent": true },
    { "source": "/diseno-de-jardines-tampico-altamira-madero", "destination": "/", "permanent": true },
    { "source": "/sistema-de-riego-tampico-madero-altamira", "destination": "/", "permanent": true },
    { "source": "/mantenimiento-de-jardin-tampico-madero-altamira", "destination": "/", "permanent": true },
    { "source": "/plantas-palmas-arboles-productos-jardineria", "destination": "/", "permanent": true },
    { "source": "/pasto-sintetico-tampico", "destination": "/", "permanent": true },
    { "source": "/tierra-negra-para-jardin-tampico", "destination": "/", "permanent": true },
    { "source": "/tezontle-rojo-jardin-tampico-madero-altamira", "destination": "/", "permanent": true },
    { "source": "/piedra-marmol-blanca-tampico", "destination": "/", "permanent": true },
    { "source": "/pasto-san-agustin-rollo", "destination": "/", "permanent": true },
